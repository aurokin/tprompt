# doctor with frontmatter key colliding with reserved key reports FAIL and exits non-zero.

mkdir prompts
! tprompt doctor --config config.toml
stdout 'ok   config loaded'
stdout 'ok   prompts directory exists'
stdout 'FAIL'
stdout 'reserved key'

-- config.toml --
prompts_dir = "prompts"

-- prompts/clash.md --
---
key: P
---

This prompt uses the default clipboard reserved key.

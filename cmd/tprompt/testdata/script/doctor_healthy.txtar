# doctor with valid config and prompts reports all ok (except tmux).

mkdir prompts
tprompt doctor --config config.toml
stdout 'ok   config loaded'
stdout 'ok   prompts directory exists'
stdout 'ok   2 prompts discovered'
stdout 'warn not inside tmux'
! stderr .

-- config.toml --
prompts_dir = "prompts"


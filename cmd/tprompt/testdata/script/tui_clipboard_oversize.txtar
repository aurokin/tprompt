# `tprompt tui` with a clipboard body exceeding max_paste_bytes exits
# ExitPrompt (3) with BodyTooLargeError on stderr. The Submitter rejects
# before dialing Submit, so the daemon is preflight-dialed but never
# receives a submission.

[!exec:tmux] skip

env TMUX_TMPDIR=$SHORT_TMPDIR
# 10 bytes; config caps at 5.
env TPROMPT_TEST_RENDERER=clipboard:abcdefghij

exec tmux new-session -d -s tuiclipoversize 'sleep 60'

mkdir prompts state
tprompt daemon start --config config.toml &

exec sh -c 'for i in $(seq 1 50); do test -S state/daemon.sock && exit 0; sleep 0.1; done; exit 1'

! tprompt tui --target-pane %0 --config config.toml
stderr 'body exceeds max_paste_bytes \(10 > 5\)'

exec tmux kill-server

-- config.toml --
prompts_dir = "prompts"
socket_path = "state/daemon.sock"
log_path = "state/daemon.log"
max_paste_bytes = 5

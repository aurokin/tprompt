# `tprompt tui` with a cancel-returning Renderer exits 0 after preflight.

[!exec:tmux] skip

env TMUX_TMPDIR=$SHORT_TMPDIR
env TPROMPT_TEST_RENDERER=cancel

exec tmux new-session -d -s tuicancel 'sleep 60'
exec tmux display-message -p '#{socket_path}'
stdout $SHORT_TMPDIR

mkdir prompts state
tprompt daemon start --config config.toml &

exec sh -c 'for i in $(seq 1 50); do test -S state/daemon.sock && exit 0; sleep 0.1; done; exit 1'

tprompt tui --target-pane %0 --config config.toml
! stdout .
! stderr .

exec tmux kill-server

-- config.toml --
prompts_dir = "prompts"
socket_path = "state/daemon.sock"
log_path = "state/daemon.log"

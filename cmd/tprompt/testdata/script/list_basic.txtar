# list prints prompt IDs alphabetically with resolved board key state.

mkdir prompts
tprompt list --config config.toml
stdout '^bug-hunt  key b \(explicit\)\ncode-review  key c \(explicit\)\nno-frontmatter  key 1 \(auto\)\n$'
! stderr .

-- config.toml --
prompts_dir = "prompts"

-- prompts/code-review.md --
---
title: Code Review
key: c
---

Review this code.

-- prompts/bug-hunt.md --
---
title: Bug Hunt
key: b
---

Find bugs.

-- prompts/no-frontmatter.md --
Just a body.
